{
  "schemaVersion": 1,
  "id": "sapvptiertagger",
  "version": "${version}",
  "name": "SAPVPTierTagger",
  "description": "Client-side SAPVP nametags, cache, commands and detailed player panel for Minecraft 1.21.x.",
  "authors": [
    "OpenAI Codex"
  ],
  "contact": {
    "homepage": "https://www.sapvp.com/"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.sapvp.tiertagger.SAPVPTierTaggerClient"
    ],
    "modmenu": [
      "com.sapvp.tiertagger.integration.SapvpModMenuIntegration"
    ]
  },
  "mixins": [
    "sapvptiertagger.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_range}",
    "java": ">=21",
    "fabric-api": "*",
    "cloth-config": "*"
  },
  "suggests": {
    "modmenu": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://www.sapvp.com/",
        "modmenu.modrinth": "https://modrinth.com/"
      }
    }
  }
}
